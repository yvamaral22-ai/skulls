
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para sistema de uso interno exclusivo (Single-User)
    // Permite que o barbeiro (autenticado anonimamente ou via social) tenha controle total
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
