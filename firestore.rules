rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CUSTOMER-FIRST BARBER SHOP SECURITY MODEL
     *
     * Core Philosophy:
     * This ruleset enforces a strict Ownership model based on the "Barber-as-Tenant" architecture. 
     * All application data—including clients, services, appointments, and schedule blocks—is 
     * strictly nested under a root Barber document. Access is granted only when the 
     * authenticated User ID matches the top-level Barber ID in the document path.
     */

    // --- Global Helper Functions ---

    /** Checks if the request is made by an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Combined check for ownership and document existence. 
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    match /barbers/{barberId} {
      allow get, list: if isOwner(barberId);
      allow create: if isOwner(barberId) && request.resource.data.id == barberId;
      allow update: if isExistingOwner(barberId) && request.resource.data.id == barberId;
      allow delete: if isExistingOwner(barberId);

      /** Subcollection for staff management */
      match /staff/{staffId} {
        allow get, list: if isOwner(barberId);
        allow create, update, delete: if isOwner(barberId);
      }

      /** Subcollection for clients */
      match /clients/{clientId} {
        allow get, list: if isOwner(barberId);
        allow create: if isOwner(barberId) && request.resource.data.id == clientId;
        allow update: if isExistingOwner(barberId);
        allow delete: if isExistingOwner(barberId);
      }

      /** Subcollection for services */
      match /services/{serviceId} {
        allow get, list: if isOwner(barberId);
        allow create: if isOwner(barberId) && request.resource.data.id == serviceId;
        allow update: if isExistingOwner(barberId);
        allow delete: if isExistingOwner(barberId);
      }

      /** Records of scheduled bookings. */
      match /appointments/{appointmentId} {
        allow get, list: if isOwner(barberId) || (isSignedIn() && resource.data.staffId == request.auth.uid);
        allow create: if isOwner(barberId) || (isSignedIn() && request.resource.data.staffId == request.auth.uid);
        allow update: if isOwner(barberId) || (isSignedIn() && resource.data.staffId == request.auth.uid);
        allow delete: if isOwner(barberId);
      }

      /** Periods when a barber is unavailable. */
      match /blockedTimes/{blockedTimeId} {
        allow get, list: if isOwner(barberId) || (isSignedIn() && resource.data.staffId == request.auth.uid);
        allow create: if isOwner(barberId) || (isSignedIn() && request.resource.data.staffId == request.auth.uid);
        allow update: if isOwner(barberId) || (isSignedIn() && resource.data.staffId == request.auth.uid);
        allow delete: if isOwner(barberId);
      }
    }

    /** 
     * Collection Group Support for Staff Role Detection 
     * Allows a staff member to find which barber shop they belong to.
     */
    match /{path=**}/staff/{staffId} {
      allow read: if isSignedIn() && request.auth.uid == staffId;
    }
  }
}