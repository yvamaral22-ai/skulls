
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para o perfil master da barbearia (Single-User App)
    // Isso garante que o barbeiro tenha controle absoluto sobre seus dados
    match /barberProfiles/{profileId}/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Regra de fallback para garantir acesso geral se autenticado
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
