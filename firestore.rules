
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para sistema de uso interno exclusivo (Single-User)
    // Permite acesso total ao perfil mestre da barbearia
    match /barberProfiles/master-barbershop/{document=**} {
      allow read, write: if true;
    }
    
    // Regra de fallback para garantir que o usuário autenticado tenha acesso a outros caminhos se necessário
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
