
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para o ID fixo da barbearia (Single-User)
    // Isso garante que o barbeiro mestre sempre consiga gerenciar seus dados
    match /barberProfiles/master-barbershop/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Regra de fallback para garantir acesso geral se autenticado (inclui login anônimo)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
