rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BARBERIA SKULL'S SECURITY MODEL
     * Garante isolamento entre barbearias e acesso restrito a agendas e faturamento.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(barberId) {
      return isSignedIn() && request.auth.uid == barberId;
    }

    match /barbers/{barberId} {
      // Permite que qualquer usuário logado veja informações básicas da barbearia (necessário para o Dashboard)
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 

      // Apenas o dono cria/edita a raiz da barbearia
      allow create: if isSignedIn() && request.auth.uid == barberId;
      allow update, delete: if isOwner(barberId);

      /** Subcollection for staff management */
      match /staff/{staffId} {
        // Funcionários e Dono podem ler a lista de equipe
        allow read: if isSignedIn();
        // Apenas o dono pode gerenciar a equipe
        allow write: if isOwner(barberId);
      }

      /** Subcollection for clients */
      match /clients/{clientId} {
        // Dono tem acesso total; Clientes acessam apenas seus dados
        allow read: if isOwner(barberId) || (isSignedIn() && request.auth.uid == clientId);
        allow write: if isOwner(barberId) || (isSignedIn() && request.auth.uid == clientId);
      }

      /** Subcollection for services */
      match /services/{serviceId} {
        // Menu de serviços é público para usuários logados
        allow read: if isSignedIn();
        allow write: if isOwner(barberId);
      }

      /** Records of scheduled bookings. */
      match /appointments/{appointmentId} {
        // Dono vê tudo. Funcionário vê apenas o que está designado a ele.
        allow read: if isOwner(barberId) 
          || (isSignedIn() && (resource.data.staffId == request.auth.uid || resource.data.clientId == request.auth.uid || request.auth.token.email == resource.data.staffEmail));
        
        // Qualquer um logado pode criar agendamentos (clientes ou equipe)
        allow create: if isSignedIn();
        
        // Dono e o profissional designado podem atualizar o status/checkout
        allow update: if isOwner(barberId) 
          || (isSignedIn() && (resource.data.staffId == request.auth.uid || request.auth.token.email == resource.data.staffEmail));
          
        allow delete: if isOwner(barberId);
      }
    }

    /** 
     * Permite que o funcionário se encontre via Collection Group 
     * CRITICAL: Permite a busca filtrada por e-mail para identificação de papel
     */
    match /{path=**}/staff/{staffId} {
      allow read: if isSignedIn();
    }
  }
}