
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Acesso total para o perfil master da barbearia (Single-User App)
    match /barberProfiles/master-barbershop/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Regra de fallback para garantir acesso geral se autenticado
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
