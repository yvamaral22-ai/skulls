rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CUSTOMER MANAGEMENT & SCHEDULING SYSTEM SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset enforces a strict identity-based access model. Users are partitioned into
     * Clients, Barbers, and Admins. Authorization is primarily handled through UID-to-DocumentID 
     * matching and role-based access markers.
     * 
     * Data Structure:
     * - /users/{userId}: Primary profile information.
     * - /admins/{adminId}: Secure marker collection for administrative privileges.
     * - /barbers/{barberId}: Professional barber profiles.
     * - /clients/{clientId}: Specific client metadata and internal barber notes.
     * - /appointments/{appointmentId}: Shared documents containing both clientId and barberId.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: We denormalize critical IDs (clientId, barberId) onto 
     *    appointment documents to allow rules to verify access without costly lookups.
     * 2. Role Verification: Admin status is verified by the existence of a document in the 
     *    dedicated /admins collection, avoiding circular dependencies in the /users collection.
     * 3. Prototyping Flexibility: We strictly enforce "Who" can access data (Authorization) 
     *    but remain flexible on "What" the data looks like (Schema), allowing for rapid 
     *    iteration of the beauty service offerings.
     * 4. Relational Integrity: On creation, we enforce that the internal 'id' or 'ownerId' 
     *    fields match the authenticated user to prevent data hijacking.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isBarber() {
      return isSignedIn() && exists(/databases/$(database)/documents/barbers/$(request.auth.uid));
    }

    // Helper to check if a user is part of an appointment
    function isAppointmentParticipant(apptData) {
      return isSignedIn() && (request.auth.uid == apptData.clientId || request.auth.uid == apptData.barberId || isAdmin());
    }

    // Helper for destructive operations to ensure document existence and ownership
    // FIX: 'resource' is a global variable. It must be passed as an argument to helper functions.
    // FIX: This function is now used in update rules for user-owned documents.
    function isExistingOwner(currentResource, userId) {
      return currentResource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the primary User Profile. Users can manage their own profile.
     * @path /users/{userId}
     * @allow (get, list, create, update) if the authenticated UID matches the {userId}.
     * @deny (delete) if not an Admin.
     * @principle Enforces strict document ownership and prevents user impersonation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // FIX: Use the 'isExistingOwner' helper.
      allow update: if isExistingOwner(resource, userId);
      allow delete: if isAdmin();
    }

    /**
     * @description Role marker collection. Existence here confers Admin rights.
     * @path /admins/{adminId}
     * @allow (get) if signed in.
     * @deny (list, create, update, delete) for all except existing Admins.
     * @principle Uses a dedicated path for role-based access control (RBAC) to ensure authorization independence.
     */
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description Publicly viewable barber profiles for marketing and portfolio.
     * @path /barbers/{barberId}
     * @allow (get, list) for all users (public catalog).
     * @allow (create, update) if the user owns the barber profile or is an Admin.
     * @deny (delete) for non-admins to prevent accidental loss of professional data.
     * @principle Combines public visibility with owner-only editing.
     */
    match /barbers/{barberId} {
      allow get, list: if true;
      allow create: if isOwner(barberId) || isAdmin();
      // FIX: Use the 'isExistingOwner' helper.
      allow update: if isExistingOwner(resource, barberId) || isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Management of a barber's available working hours and blocked times.
       * @path /barbers/{barberId}/availability/{availabilityId}
       * @allow (get, list) for all users to facilitate appointment booking.
       * @allow (create, update, delete) if the parent barber or an Admin.
       * @principle Relational integrity: ensures availability is only managed by the barber it belongs to.
       */
      match /availability/{availabilityId} {
        allow get, list: if true;
        allow create: if isOwner(barberId) || isAdmin();
        // FIX: Use the 'isExistingOwner' helper.
        allow update, delete: if isExistingOwner(resource, barberId) || isAdmin();
      }
    }

    /**
     * @description Detailed client profiles including private notes for barbers.
     * @path /clients/{clientId}
     * @allow (get, list) if owner, a barber (for CRM notes), or Admin.
     * @allow (create, update) if owner or Admin.
     * @deny (delete) if not Admin.
     * @principle Shared visibility between the client and the professional service provider.
     */
    match /clients/{clientId} {
      allow get, list: if isOwner(clientId) || isBarber() || isAdmin();
      allow create: if isOwner(clientId) || isAdmin();
      // FIX: Use the 'isExistingOwner' helper.
      allow update: if isExistingOwner(resource, clientId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description The barbershop's service menu (Cuts, Shaves, etc.).
     * @path /services/{serviceId}
     * @allow (get, list) for everyone.
     * @allow (create, update, delete) restricted to Admins.
     * @principle Public read access for customer browsing with strict administrative control over business offerings.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      /**
       * @description Portfolio images showcasing specific service results.
       * @path /services/{serviceId}/images/{imageId}
       * @allow (get, list) for everyone.
       * @allow (create, update, delete) restricted to Admins.
       * @principle Visual gallery management restricted to shop management.
       */
      match /images/{imageId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Critical scheduling records linking clients and barbers.
     * @path /appointments/{appointmentId}
     * @allow (get, list) if the user's UID is either the clientId or barberId in the document.
     * @allow (create) if the user is the clientId (self-booking) or an Admin.
     * @allow (update) if a participant, provided critical relations (clientId/barberId) don't change.
     * @principle Shared access model utilizing denormalized IDs for performant, secure list queries.
     */
    match /appointments/{appointmentId} {
      // FIX: Split 'get' and 'list' operations. 'resource.data' is not available for 'list'.
      allow get: if isAppointmentParticipant(resource.data);
      // FIX: For 'list', require admin or a query constraint from the authenticated participant.
      allow list: if isAdmin() || (
        isSignedIn() &&
        (request.query.where.get('clientId', null) == request.auth.uid ||
         request.query.where.get('barberId', null) == request.auth.uid)
      );
      allow create: if isSignedIn() && (request.resource.data.clientId == request.auth.uid || isAdmin());
      allow update: if resource != null && isAppointmentParticipant(resource.data) && (request.resource.data.clientId == resource.data.clientId);
      allow delete: if isAdmin();
    }

    /**
     * @description Operational business expenses (Rent, Supplies).
     * @path /expenses/{expenseId}
     * @allow (get, list, create, update, delete) restricted to Admins only.
     * @principle Financial data isolation; strictly hidden from barbers and clients.
     */
    match /expenses/{expenseId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}