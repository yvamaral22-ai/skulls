
{
  "entities": {
    "BarberProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BarberProfile",
      "type": "object",
      "description": "Perfil da barbearia (Tenant/Dono).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "businessName": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" },
        "commissionRate": { "type": "number", "description": "Comissão padrão (ex: 0.4 para 40%)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "businessName", "createdAt"]
    },
    "Staff": {
      "title": "Staff",
      "type": "object",
      "description": "Barbeiros da equipe.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "photoUrl": { "type": "string" },
        "commissionRate": { "type": "number" },
        "bio": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "barberProfileId", "name", "isActive"]
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Clientes vinculados à barbearia.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferences": { "type": "string", "description": "Notas técnicas e preferências." }
      },
      "required": ["id", "barberProfileId", "name"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Serviços oferecidos no catálogo.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "durationMinutes": { "type": "number" }
      },
      "required": ["id", "barberProfileId", "name", "price", "durationMinutes"]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Registro de agendamentos e transações.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "staffId": { "type": "string" },
        "clientName": { "type": "string" },
        "serviceId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "canceled"] },
        "paymentMethod": { "type": "string", "enum": ["Cash", "Credit", "Debit", "PIX"] },
        "priceAtAppointment": { "type": "number" },
        "commissionAtAppointment": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["id", "barberProfileId", "staffId", "clientName", "serviceId", "date", "time", "status"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Despesas operacionais da barbearia.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string" }
      },
      "required": ["id", "barberProfileId", "description", "amount", "date"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/barberProfiles/{barberProfileId}": {
      "schema": "#/entities/BarberProfile",
      "description": "Perfil principal da barbearia."
    },
    "/barberProfiles/{barberProfileId}/staff/{staffId}": {
      "schema": "#/entities/Staff",
      "description": "Membros da equipe de barbeiros."
    },
    "/barberProfiles/{barberProfileId}/clients/{clientId}": {
      "schema": "#/entities/Client",
      "description": "Base de clientes da barbearia."
    },
    "/barberProfiles/{barberProfileId}/services/{serviceId}": {
      "schema": "#/entities/Service",
      "description": "Catálogo de serviços e preços."
    },
    "/barberProfiles/{barberProfileId}/appointments/{appointmentId}": {
      "schema": "#/entities/Appointment",
      "description": "Histórico de agendamentos e vendas."
    },
    "/barberProfiles/{barberProfileId}/expenses/{expenseId}": {
      "schema": "#/entities/Expense",
      "description": "Controle de saídas financeiras."
    }
  }
}
