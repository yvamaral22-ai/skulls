
{
  "entities": {
    "BarberProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BarberProfile",
      "type": "object",
      "description": "Perfil da barbearia (Tenant/Dono).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "businessName": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" },
        "commissionRate": { "type": "number", "description": "Comissão padrão (ex: 0.4 para 40%)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "businessName", "createdAt"]
    },
    "Staff": {
      "title": "Staff",
      "type": "object",
      "description": "Barbeiros da equipe.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "photoUrl": { "type": "string" },
        "commissionRate": { "type": "number" },
        "bio": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "barberProfileId", "name", "isActive"]
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Clientes vinculados à barbearia.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferences": { "type": "string", "description": "Notas técnicas e preferências." }
      },
      "required": ["id", "barberProfileId", "name"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Serviços oferecidos no catálogo.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "durationMinutes": { "type": "number" }
      },
      "required": ["id", "barberProfileId", "name", "price", "durationMinutes"]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Registro de agendamentos e transações.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "staffId": { "type": "string" },
        "clientId": { "type": "string" },
        "serviceId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Scheduled", "Completed", "Canceled"] },
        "priceAtAppointment": { "type": "number" },
        "commissionAtAppointment": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["id", "barberProfileId", "staffId", "clientId", "serviceId", "startTime", "status"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Despesas operacionais da barbearia.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string" }
      },
      "required": ["id", "barberProfileId", "description", "amount", "date"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/barberProfiles/{barberProfileId}",
        "definition": { "entityName": "BarberProfile" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/staff/{staffId}",
        "definition": { "entityName": "Staff" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/clients/{clientId}",
        "definition": { "entityName": "Client" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/services/{serviceId}",
        "definition": { "entityName": "Service" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/appointments/{appointmentId}",
        "definition": { "entityName": "Appointment" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/expenses/{expenseId}",
        "definition": { "entityName": "Expense" }
      }
    ]
  }
}
