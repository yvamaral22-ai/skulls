
{
  "entities": {
    "BarberProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BarberProfile",
      "type": "object",
      "description": "Perfil da barbearia (Dono).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "businessName": { "type": "string" },
        "commissionRate": { "type": "number", "description": "Comissão padrão para os barbeiros (ex: 0.4 para 40%)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "businessName", "createdAt"]
    },
    "Staff": {
      "title": "Staff",
      "type": "object",
      "description": "Representa os barbeiros que trabalham na barbearia.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "commissionRate": { "type": "number", "description": "Comissão específica deste barbeiro." },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "barberProfileId", "name", "isActive"]
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "preferences": { "type": "string" }
      }
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "durationMinutes": { "type": "number" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "staffId": { "type": "string", "description": "ID do barbeiro que realizou o serviço." },
        "clientId": { "type": "string" },
        "serviceId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Scheduled", "Completed", "Canceled"] },
        "priceAtAppointment": { "type": "number" },
        "commissionAtAppointment": { "type": "number", "description": "Valor da comissão calculada na conclusão." }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Controle de despesas básicas da barbearia.",
      "properties": {
        "id": { "type": "string" },
        "barberProfileId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/barberProfiles/{barberProfileId}",
        "definition": { "entityName": "BarberProfile" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/staff/{staffId}",
        "definition": { "entityName": "Staff" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/clients/{clientId}",
        "definition": { "entityName": "Client" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/services/{serviceId}",
        "definition": { "entityName": "Service" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/appointments/{appointmentId}",
        "definition": { "entityName": "Appointment" }
      },
      {
        "path": "/barberProfiles/{barberProfileId}/expenses/{expenseId}",
        "definition": { "entityName": "Expense" }
      }
    ]
  }
}
