{
  "entities": {
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Represents a customer of the barber shop.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferences": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Service": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Service",
      "type": "object",
      "description": "Defines a service offered by the barber shop.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "price": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "Barber": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Barber",
      "type": "object",
      "description": "Represents a barber shop owner.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "Staff": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Staff",
      "type": "object",
      "description": "Represents a barber employee.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["STAFF", "ADMIN"] },
        "isActive": { "type": "boolean" }
      }
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Records a scheduled service booking.",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "staffId": { "type": "string" },
        "serviceId": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string" },
        "priceAtAppointment": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": [ "password", "google.com" ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/barbers/{barberId}",
        "definition": {
          "entityName": "Barber",
          "schema": { "$ref": "#/backend/entities/Barber" },
          "description": "Root for all shop data."
        }
      },
      {
        "path": "/barbers/{barberId}/staff/{staffId}",
        "definition": {
          "entityName": "Staff",
          "schema": { "$ref": "#/backend/entities/Staff" },
          "description": "Employees of the shop."
        }
      },
      {
        "path": "/barbers/{barberId}/clients/{clientId}",
        "definition": {
          "entityName": "Client",
          "schema": { "$ref": "#/backend/entities/Client" },
          "description": "Customers of the shop."
        }
      },
      {
        "path": "/barbers/{barberId}/services/{serviceId}",
        "definition": {
          "entityName": "Service",
          "schema": { "$ref": "#/backend/entities/Service" },
          "description": "Services offered."
        }
      },
      {
        "path": "/barbers/{barberId}/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": { "$ref": "#/backend/entities/Appointment" },
          "description": "Bookings for the shop."
        }
      }
    ]
  }
}
